{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run API (Development)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "backend: build",
      "program": "${workspaceFolder}/backend/src/NovaLearn.API/bin/Debug/net9.0/NovaLearn.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/src/NovaLearn.API",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7001;http://localhost:5001"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "https://localhost:7001/swagger"
      }
    }
  ]
}
